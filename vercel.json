{
  "devCommand": "uvicorn api.index:app --host 0.0.0.0 --port 3000",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/static/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@0.10.3"
    }
  }
}
